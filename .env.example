# DKG SelectieTool — environment variables
# Kopieer naar .env en vul in. .env wordt NIET gecommit.
# Gevoelige bestanden worden extra afgeschermd door .htaccess.

# ─── Applicatie ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=DKG SelectieTool
APP_BASE_URL=https://selectie.jouwdomein.nl

# 32-byte random key voor encryptie (mail-pwd in DB). Wordt door de install-
# wizard automatisch gegenereerd. NOOIT delen; verlies = mail-pwd opnieuw invoeren.
APP_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Mail (bootstrap-defaults — settings-UI overschrijft deze in fase 2) ─────
# Driver: 'log' (naar logs/mail.log, geen echte verzending) of 'smtp'
MAIL_DRIVER=log
MAIL_FROM=noreply@localhost
MAIL_FROM_NAME=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
